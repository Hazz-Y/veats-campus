// VEats — Jenkinsfile Example
// Mirrors the GitHub Actions CI/CD pipeline

pipeline {
    agent any

    environment {
        DATABASE_URL = 'postgresql://veats:veats_ci@localhost:5432/veats_ci?schema=public'
        JWT_SECRET   = 'ci-test-jwt-secret'
    }

    stages {
        stage('Backend - Install') {
            steps {
                dir('backend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Backend - Lint') {
            steps {
                dir('backend') {
                    sh 'npm run lint'
                }
            }
        }

        stage('Backend - Generate Prisma') {
            steps {
                dir('backend') {
                    sh 'npx prisma generate'
                }
            }
        }

        stage('Backend - Test') {
            steps {
                dir('backend') {
                    sh 'npm test'
                }
            }
        }

        stage('Backend - Build') {
            steps {
                dir('backend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Frontend - Install') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                }
            }
        }

        stage('Frontend - Lint') {
            steps {
                dir('frontend') {
                    sh 'npm run lint'
                }
            }
        }

        stage('Frontend - Test') {
            steps {
                dir('frontend') {
                    sh 'npm test -- --passWithNoTests'
                }
            }
        }

        stage('Frontend - Build') {
            steps {
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Build') {
            when {
                branch 'main'
            }
            steps {
                sh 'docker build -f infra/Dockerfile.backend -t veats-backend:ci ./backend'
                sh 'docker build -f infra/Dockerfile.frontend -t veats-frontend:ci ./frontend'
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                echo 'TODO: Deploy to cloud provider'
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
